# =============================================================================
# Claude Code Bot — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# ----------------------- Storage -----------------------
DATABASE_URL=postgres://ccb:ccb@localhost:5432/ccb
REDIS_URL=redis://localhost:6379

# ----------------------- Discord -----------------------
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: scope slash commands to a single guild for instant updates.
DISCORD_GUILD_ID=
# Comma-separated Discord user IDs allowed to invoke privileged commands.
DISCORD_ADMIN_IDS=
# How many recent channel messages @mention chat reads as context (0-50, default 15).
CHAT_CONTEXT_MESSAGES=15

# ----------------------- GitHub ------------------------
# Personal access token with `repo` scope (or fine-grained equivalent).
# Needed for private clones AND for Claude to push branches / open PRs.
GITHUB_TOKEN=
# Identity used for AI-authored commits (override per-repo as needed).
GIT_AUTHOR_NAME=vuluu2k
GIT_AUTHOR_EMAIL=vuluu040320@gmail.com

# ----------------------- Claude ------------------------
# Auth — set ONE of the following (in order of preference):
#   1. Long-lived OAuth token for Max/Pro plans. Generate with `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=
#   2. Pay-as-you-go API key from console.anthropic.com.
ANTHROPIC_API_KEY=
#   3. Or neither — rely on cached `claude /login` credentials in $HOME/.claude.
#
# Path to the Claude Code CLI binary. Defaults to "claude" on PATH.
CLAUDE_BIN=claude
# Per-task timeout (ms). Defaults to 15 minutes.
CLAUDE_TIMEOUT_MS=900000
# Hard cap on captured stdout/stderr bytes per task.
CLAUDE_MAX_OUTPUT_BYTES=2000000
# Auto-allow tool calls in headless mode. Required for Claude to edit files.
# Set to "false" to require a settings.json allow-list instead. Default: true.
CLAUDE_SKIP_PERMISSIONS=true

# ----------------------- API ---------------------------
API_PORT=4000
API_BASE_URL=http://localhost:4000

# ----------------------- Workspaces --------------------
# Absolute path where cloned repos and worktrees live.
WORKSPACE_ROOT=./workspaces

# ----------------------- Worker ------------------------
WORKER_CONCURRENCY=2
TASK_TIMEOUT_MS=900000

# ----------------------- Cleanup -----------------------
# Remove one-off task worktrees older than this (ms). Default 24h.
WORKTREE_TTL_MS=86400000
# Close Discord threads idle longer than this and drop their worktrees. Default 7d.
THREAD_IDLE_TTL_MS=604800000
# How often the cleanup loop runs (ms). Default 1h.
CLEANUP_INTERVAL_MS=3600000
